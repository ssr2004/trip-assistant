# 梦旅环境变量配置示例
# 复制为 .env 后按需填写。不要提交真实 API Key。

# 应用基础配置
APP_NAME=梦旅
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# LLM 配置（推荐使用 DeepSeek 官方 API；OpenAI-compatible 接口）
# LLM_API_KEY 为空时系统使用规则逻辑降级，不会请求真实 LLM。
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.7
LLM_PLANNER_ENABLED=false
# auto: complex travel requests use LLM planning when a key is available; off: never; always: attempt whenever safe
LLM_PLANNER_MODE=auto
LLM_PLANNER_COMPLEXITY_THRESHOLD=3
# 行程生成默认优先使用 LLM；未配置 LLM_API_KEY 或校验失败时自动回退规则行程。
ITINERARY_LLM_ENABLED=true

# Embedding 配置（推荐阿里云百炼 text-embedding-v4，OpenAI-compatible 接口）
# EMBEDDING_API_KEY 为空时系统使用确定性本地向量降级，不会请求真实 embedding 服务。
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# RAG 配置
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5
RAG_MIN_HIT_SCORE=0.55
RAG_CHUNK_DEDUPE_THRESHOLD=0.88
RAG_MIN_CHUNK_LENGTH=80

# Tavily 搜索增强配置
# TAVILY_SEARCH_ENABLED 默认开启；未配置 TAVILY_API_KEY 时会明确降级，不会编造攻略。
TAVILY_SEARCH_ENABLED=true
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
# 可选：限制 Tavily 搜索域名。留空表示不限制；如配置 xiaohongshu.com，系统会在低质量结果时自动补搜。
TAVILY_INCLUDE_DOMAINS=
TAVILY_SEARCH_DEPTH=basic
TAVILY_INCLUDE_RAW_CONTENT=true
TAVILY_GUIDE_TTL_DAYS=30

# 数据库配置
DATABASE_URL=sqlite:///./data/travelmind.db

# 外部 API 通用配置
# 无真实 Key 或测试环境下保持 EXTERNAL_API_MOCK_ENABLED=true，可使用本地 mock fallback。
EXTERNAL_API_TIMEOUT=10
EXTERNAL_API_RETRY_TIMES=2
EXTERNAL_API_MOCK_ENABLED=true

# 外部 API 缓存配置
# Redis 不可用时系统会降级为内存缓存，保证本地无 Redis 也能运行。
EXTERNAL_API_CACHE_ENABLED=true
EXTERNAL_API_CACHE_TTL=3600
EXTERNAL_API_CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# 合规开放 API 配置
# 请只在本地 .env 中填写真实 Key，不要提交到 Git，也不要发送给助手。
# AMAP_API_KEY 使用高德开放平台 Web服务 Key，当前覆盖 POI、路线距离和天气查询。
# WEATHER_API_KEY 可选；为空时天气客户端会复用 AMAP_API_KEY。
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMAP_API_KEY=
WEATHER_API_KEY=

# MCP 真实数据源配置
# 12306 MCP 默认通过 uvx mcp-server-12306 启动，通常不需要额外 Key。
# 高德 MCP 默认通过 npx -y @amap/amap-maps-mcp-server 启动，并复用 AMAP_API_KEY。
MCP_ENABLED=true
MCP_TIMEOUT=20
MCP_12306_ENABLED=true
MCP_12306_URL=
MCP_12306_COMMAND=npx
MCP_12306_ARGS=-y 12306-mcp
MCP_AMAP_ENABLED=true
MCP_AMAP_URL=
MCP_AMAP_COMMAND=npx
MCP_AMAP_ARGS=-y @amap/amap-maps-mcp-server
MCP_FLIGHT_ENABLED=false
MCP_FLIGHT_URL=
MCP_FLIGHT_COMMAND=
MCP_FLIGHT_ARGS=

# 记忆系统配置
MEMORY_MAX_TURNS=20
LONG_TERM_MEMORY_ENABLED=true
