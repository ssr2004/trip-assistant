# TravelMind 环境变量配置示例
# 复制为 .env 后按需填写。不要提交真实 API Key。

# 应用基础配置
APP_NAME=TravelMind
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# LLM 配置（后续接入 DeepSeek / GLM / Qwen / OpenAI 兼容接口）
# LLM_API_KEY 为空时系统使用规则逻辑降级，不会请求真实 LLM。
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.7

# Embedding 配置（后续 RAG 向量检索使用）
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1

# RAG 配置
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5

# 数据库配置
DATABASE_URL=sqlite:///./data/travelmind.db

# 合规开放 API 配置
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMAP_API_KEY=

# 记忆系统配置
MEMORY_MAX_TURNS=20
LONG_TERM_MEMORY_ENABLED=true
