# TravelMind 环境变量配置示例
# 复制为 .env 后按需填写。不要提交真实 API Key。

# 应用基础配置
APP_NAME=TravelMind
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# LLM 配置（推荐使用 DeepSeek 官方 API；OpenAI-compatible 接口）
# LLM_API_KEY 为空时系统使用规则逻辑降级，不会请求真实 LLM。
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.7
# auto: complex travel requests use LLM planning when a key is available; off: never; always: attempt whenever safe
LLM_PLANNER_MODE=auto
LLM_PLANNER_COMPLEXITY_THRESHOLD=3

# Embedding 配置（推荐阿里云百炼 text-embedding-v4，OpenAI-compatible 接口）
# EMBEDDING_API_KEY 为空时系统使用确定性本地向量降级，不会请求真实 embedding 服务。
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# RAG 配置
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5

# 数据库配置
DATABASE_URL=sqlite:///./data/travelmind.db

# 外部 API 通用配置
# 无真实 Key 或测试环境下保持 EXTERNAL_API_MOCK_ENABLED=true，可使用本地 mock fallback。
EXTERNAL_API_TIMEOUT=10
EXTERNAL_API_RETRY_TIMES=2
EXTERNAL_API_MOCK_ENABLED=true

# 外部 API 缓存配置
# Redis 不可用时系统会降级为内存缓存，保证本地无 Redis 也能运行。
EXTERNAL_API_CACHE_ENABLED=true
EXTERNAL_API_CACHE_TTL=3600
EXTERNAL_API_CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# 合规开放 API 配置
# 请只在本地 .env 中填写真实 Key，不要提交到 Git，也不要发送给助手。
# AMAP_API_KEY 使用高德开放平台 Web服务 Key，当前覆盖 POI、路线距离和天气查询。
# WEATHER_API_KEY 可选；为空时天气客户端会复用 AMAP_API_KEY。
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMAP_API_KEY=
WEATHER_API_KEY=

# 记忆系统配置
MEMORY_MAX_TURNS=20
LONG_TERM_MEMORY_ENABLED=true
